# Get Food Details Function returns all nutrition data
def get_food_details(food_id, token):
    url = "https://platform.fatsecret.com/rest/server.api"
    headers = {"Authorization": f"Bearer {token}"}
    params = {
        "method": "food.get",
        "food_id": food_id,
        "format": "json"
    }

    response = requests.get(url, headers=headers, params=params)
    return response.json()
# Extract Macros Function
def extract_macros(food_data):
    try:
        servings = food_data["food"]["servings"]["serving"]

        # Sometimes it's a list, sometimes a single object
        if isinstance(servings, list):
            serving = servings[0]
        else:
            serving = servings

        return {
            "calories": float(serving.get("calories", 0)),
            "protein": float(serving.get("protein", 0)),
            "carbs": float(serving.get("carbohydrate", 0)),
            "fat": float(serving.get("fat", 0))
        }
    except Exception as e:
        print("Error extracting macros:", e)
        return None
